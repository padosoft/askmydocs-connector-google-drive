{
    "name": "padosoft/askmydocs-connector-google-drive",
    "description": "Google Drive connector for AskMyDocs — OAuth2 + multi-mime sync (markdown / plain / pdf / Google Docs as markdown export) + delta cursor for incremental sync. Drop-in package that auto-registers via composer extra discovery.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": [
        "laravel",
        "askmydocs",
        "google-drive",
        "oauth",
        "rag",
        "knowledge-base",
        "padosoft"
    ],
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "padosoft/askmydocs-connector-base": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "orchestra/testbench": "^10.0|^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\AskMyDocsConnectorGoogleDrive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\AskMyDocsConnectorGoogleDrive\\Tests\\": "tests/",
            "Padosoft\\AskMyDocsConnectorGoogleDrive\\Tests\\Support\\": "tests/Support/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\AskMyDocsConnectorGoogleDrive\\GoogleDriveServiceProvider"
            ]
        },
        "askmydocs": {
            "connectors": [
                "Padosoft\\AskMyDocsConnectorGoogleDrive\\GoogleDriveConnector"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "_comment": "TODO(lorenzo): remove this entry once padosoft/askmydocs-connector-base v1.1.0 is live on Packagist. The path repo is only used during local dev before the base package's Packagist registration propagates.",
            "type": "path",
            "url": "../askmydocs-connector-base",
            "options": {
                "symlink": false,
                "versions": {
                    "padosoft/askmydocs-connector-base": "1.1.0"
                }
            }
        }
    ]
}
